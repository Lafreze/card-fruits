{
  "name": "fruit-kingdom",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c magenta,cyan \"vite --host 0.0.0.0\" \"node --watch server/index.mjs\"",
    "build": "tsc -b && vite build",
    "start": "node server/index.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "node --test server/*.test.mjs"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "matter-js": "^0.20.0",
    "pg": "^8.16.3",
    "pixi.js": "^8.12.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}
